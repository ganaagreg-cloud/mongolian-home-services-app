# Copy this file to .env and fill in the OAuth secrets.
# Everything else is pre-filled for local Docker dev.
#
#   cp .env.example .env
#   docker compose up --build

# ── Auth ──────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=fbef953caa77fede96c435b8d6526f54566972ed2c06c959929f0536d93240e1
JWT_SECRET=dev-secret-replace-before-production

# ── OAuth (fill these in — get them from your password manager) ───────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
