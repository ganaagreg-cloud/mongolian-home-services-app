{
  "name": "homeservices",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@homeservices/api",
    "dev:web": "turbo dev --filter=@homeservices/web",
    "dev:admin": "turbo dev --filter=@homeservices/admin",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "packageManager": "pnpm@11.3.0"
}
